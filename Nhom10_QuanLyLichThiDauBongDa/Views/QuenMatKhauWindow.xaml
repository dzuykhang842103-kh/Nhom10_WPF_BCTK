<Window x:Class="Nhom10_QuanLyLichThiDauBongDa.Views.QuenMatKhauWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Nhom10_QuanLyLichThiDauBongDa.ViewModels"
        Title="Cấp Lại Mật Khẩu" Height="450" Width="350"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None" Background="#2C3E50">

    <Window.DataContext>
       <vm:QuenMatKhauViewModel/>
    </Window.DataContext>

    <Border BorderBrush="#34495E" BorderThickness="2" CornerRadius="10">
        <StackPanel Margin="25">
            <TextBlock Text="CẤP LẠI MẬT KHẨU" FontSize="22" FontWeight="Bold" Foreground="#F1C40F" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Tên đăng nhập:" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding TenDangNhap}" Height="30" Padding="5" Margin="0,0,0,15" Background="#ECF0F1"/>

            <TextBlock Text="Mã bảo mật (Master Key):" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtSecretKey" Height="30" Padding="5" Margin="0,0,0,15" Background="#ECF0F1"/>

            <TextBlock Text="Mật khẩu mới:" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtNewPass" Height="30" Padding="5" Margin="0,0,0,15" Background="#ECF0F1"/>

            <TextBlock Text="Xác nhận mật khẩu mới:" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtConfirmPass" Height="30" Padding="5" Margin="0,0,0,25" Background="#ECF0F1"/>

            <Button Content="XÁC NHẬN ĐỔI MẬT KHẨU" 
        Command="{Binding XacNhanCommand}" 
        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
        Background="#27AE60" Foreground="White" FontWeight="Bold" Height="40" Margin="0,0,0,10">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="Hủy bỏ" Command="{Binding ThoatCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Background="Transparent" Foreground="#E74C3C" BorderBrush="Transparent" FontWeight="SemiBold" Height="30"/>
        </StackPanel>
    </Border>
</Window>