<Window x:Class="Nhom10_QuanLyLichThiDauBongDa.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Nhom10_QuanLyLichThiDauBongDa.ViewModels"
        Title="Hệ Thống Quản Lý Lịch Thi Đấu Bóng Đá" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BackgroundColor}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PrimaryColor}">
            <StackPanel>
                <TextBlock Text="FOOTBALL LEAGUE" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,30,0,40"/>

                <Button Content="Quản lý Đội bóng" Command="{Binding ShowDoiBongCommand}" Background="Transparent" Foreground="White" FontSize="16" Height="50" HorizontalContentAlignment="Left" Padding="20,0,0,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Quản lý Cầu thủ" Command="{Binding ShowCauThuCommand}" Background="Transparent" Foreground="White" FontSize="16" Height="50" HorizontalContentAlignment="Left" Padding="20,0,0,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Tạo lịch &amp; Kết quả" Command="{Binding ShowLichThiDauCommand}" Background="Transparent" Foreground="White" FontSize="16" Height="50" HorizontalContentAlignment="Left" Padding="20,0,0,0" BorderThickness="0" Cursor="Hand"/>

                <Rectangle Height="1" Fill="#34495E" Margin="20,20"/>

                <Button Content="Thống kê / Xếp hạng" Command="{Binding ShowThongKeCommand}" Background="Transparent" Foreground="White" FontSize="16" Height="50" HorizontalContentAlignment="Left" Padding="20,0,0,0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <TextBlock Text="BẢNG ĐIỀU KHIỂN" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentUserInfo}" FontSize="14" FontWeight="SemiBold" Foreground="#7F8C8D" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Content="Đăng xuất" Command="{Binding LogoutCommand}" Style="{StaticResource PrimaryButton}" Height="30" Padding="15,0" Background="{StaticResource AccentColor}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="15">
                <ContentControl Content="{Binding CurrentView}"/>
            </Border>
        </Grid>
    </Grid>
</Window>