<UserControl x:Class="Nhom10_QuanLyLichThiDauBongDa.Views.Controls.TranDauUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Nhom10_QuanLyLichThiDauBongDa.ViewModels"
             xml:lang="vi-VN"
             Background="White">

    <UserControl.DataContext>
        <vm:TranDauViewModel/>
    </UserControl.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="QUẢN LÝ LỊCH THI ĐẤU VÀ KẾT QUẢ" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,15"/>

        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15" Background="#FDFDFD">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Đội Nhà:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding DanhSachDoiBong}" SelectedItem="{Binding SelectedDoiNha}" DisplayMemberPath="TenDoi" Height="35" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Đội Khách:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding DanhSachDoiBong}" SelectedItem="{Binding SelectedDoiKhach}" DisplayMemberPath="TenDoi" Height="35" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Ngày thi đấu:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding NgayThiDau}" Height="35" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Vòng đấu:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding VongDau, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBox}"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Bàn thắng Đội nhà:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding BanThangNha, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBox}" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="1" Grid.Column="3" Text="Bàn thắng Đội khách:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding BanThangKhach, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBox}" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="2" Grid.Column="3" Text="Trạng thái:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <ComboBox Grid.Row="2" Grid.Column="4" ItemsSource="{Binding DanhSachTrangThai}" SelectedItem="{Binding SelectedTrangThai}" Height="35" Margin="0,0,0,15" Padding="5"/>

                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0" Visibility="{Binding AdminVisibility}">
                    <Button Content="Cập nhật diễn biến" Command="{Binding ChiTietCommand}" Style="{StaticResource PrimaryButton}" Width="150" Margin="0,0,20,0" Background="#3498DB"/>
                    <Button Content="Tạo lịch tự động" Command="{Binding SinhLichTuDongCommand}" Style="{StaticResource PrimaryButton}" Width="130" Margin="0,0,20,0" Background="#8E44AD"/>
                    <Button Content="Thêm" Command="{Binding ThemCommand}" Style="{StaticResource PrimaryButton}" Width="80" Margin="0,0,10,0" Background="#27AE60"/>
                    <Button Content="Sửa" Command="{Binding SuaCommand}" Style="{StaticResource PrimaryButton}" Width="80" Margin="0,0,10,0" Background="#F39C12"/>
                    <Button Content="Xóa" Command="{Binding XoaCommand}" Style="{StaticResource PrimaryButton}" Width="80" Margin="0,0,10,0" Background="#E74C3C"/>
                    <Button Content="Làm mới" Command="{Binding LamMoiCommand}" Style="{StaticResource PrimaryButton}" Width="80" Background="#95A5A6"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSachTranDau}" SelectedItem="{Binding SelectedTranDau}" 
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  Background="Transparent" BorderBrush="#E0E0E0" BorderThickness="1" RowHeight="35" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F2F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Trận" Binding="{Binding MaTranDau}" Width="70"/>
                <DataGridTextColumn Header="Đội Nhà" Binding="{Binding DoiBong1.TenDoi}" Width="150" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Đội Khách" Binding="{Binding DoiBong.TenDoi}" Width="150" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Ngày Thi Đấu" Binding="{Binding NgayThiDau, StringFormat=dd/MM/yyyy}" Width="120"/>
                <DataGridTextColumn Header="Vòng" Binding="{Binding VongDau}" Width="60"/>
                <DataGridTextColumn Header="Bàn Nhà" Binding="{Binding BanThangNha}" Width="80"/>
                <DataGridTextColumn Header="Bàn Khách" Binding="{Binding BanThangKhach}" Width="80"/>
                <DataGridTextColumn Header="Trạng Thái" Binding="{Binding TrangThai}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>