<UserControl x:Class="Nhom10_QuanLyLichThiDauBongDa.Views.Controls.DoiBongUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Nhom10_QuanLyLichThiDauBongDa.ViewModels"
             Background="White">

    <UserControl.DataContext>
        <vm:DoiBongViewModel/>
    </UserControl.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="QUẢN LÝ DANH MỤC ĐỘI BÓNG" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,15"/>

        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15" Background="#FDFDFD">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Tên đội bóng:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TenDoi, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBox}" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Thành phố:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ThanhPho, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBox}" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Sân vận động:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding SanVanDong, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBox}" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="1" Grid.Column="3" Text="Huấn luyện viên:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding HuanLuyenVien, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBox}" Margin="0,0,0,15"/>

                <StackPanel Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Visibility="{Binding AdminVisibility}">
                    <Button Content="Thêm" Command="{Binding ThemCommand}" Style="{StaticResource PrimaryButton}" Width="80" Margin="0,0,10,0" Background="#27AE60"/>
                    <Button Content="Sửa" Command="{Binding SuaCommand}" Style="{StaticResource PrimaryButton}" Width="80" Margin="0,0,10,0" Background="#F39C12"/>
                    <Button Content="Xóa" Command="{Binding XoaCommand}" Style="{StaticResource PrimaryButton}" Width="80" Margin="0,0,10,0" Background="#E74C3C"/>
                    <Button Content="Làm mới" Command="{Binding LamMoiCommand}" Style="{StaticResource PrimaryButton}" Width="80" Background="#95A5A6"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSachDoiBong}" SelectedItem="{Binding SelectedDoiBong}" 
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  Background="Transparent" BorderBrush="#E0E0E0" BorderThickness="1" RowHeight="35" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F2F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Đội" Binding="{Binding MaDoiBong}" Width="80"/>
                <DataGridTextColumn Header="Tên Đội Bóng" Binding="{Binding TenDoi}" Width="*" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Thành Phố" Binding="{Binding ThanhPho}" Width="150"/>
                <DataGridTextColumn Header="Sân Vận Động" Binding="{Binding SanVanDong}" Width="150"/>
                <DataGridTextColumn Header="Huấn Luyện Viên" Binding="{Binding HuanLuyenVien}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>