<UserControl x:Class="Nhom10_QuanLyLichThiDauBongDa.Views.Controls.CauThuUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Nhom10_QuanLyLichThiDauBongDa.ViewModels"
             Background="White">

    <UserControl.DataContext>
        <vm:CauThuViewModel/>
    </UserControl.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="QUẢN LÝ DANH SÁCH CẦU THỦ" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,15"/>

        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15" Background="#FDFDFD">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Họ tên:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding HoTen, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBox}" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Đội bóng:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding DanhSachDoiBong}" SelectedItem="{Binding SelectedDoiBong}" DisplayMemberPath="TenDoi" Height="35" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Vị trí:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding DanhSachViTri}" SelectedItem="{Binding ViTri}" Height="35" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Tuổi (15-50):" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding Tuoi, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBox}" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="1" Grid.Column="3" Text="Số áo (1-99):" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,15"/>
                <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding SoAo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBox}" Margin="0,0,0,15"/>

                <StackPanel Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="{Binding AdminVisibility}">
                    <Button Content="Thêm" Command="{Binding ThemCommand}" Style="{StaticResource PrimaryButton}" Width="80" Margin="0,0,10,0" Background="#27AE60"/>
                    <Button Content="Sửa" Command="{Binding SuaCommand}" Style="{StaticResource PrimaryButton}" Width="80" Margin="0,0,10,0" Background="#F39C12"/>
                    <Button Content="Xóa" Command="{Binding XoaCommand}" Style="{StaticResource PrimaryButton}" Width="80" Margin="0,0,10,0" Background="#E74C3C"/>
                    <Button Content="Làm mới" Command="{Binding LamMoiCommand}" Style="{StaticResource PrimaryButton}" Width="80" Background="#95A5A6"/>
                </StackPanel>

                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="6" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Background="#ECF0F1" Margin="0,0,0,15" ClipToBounds="True">
                    <Grid>
                        <TextBlock Text="Chưa có ảnh" Foreground="#7F8C8D" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image Source="{Binding HinhAnh}" Stretch="UniformToFill"/>
                    </Grid>
                </Border>
                <Button Grid.Row="2" Grid.Column="6" Content="Tải ảnh lên" Command="{Binding ChonAnhCommand}" Style="{StaticResource PrimaryButton}" Background="#3498DB" Height="30" Margin="0,0,0,10" Padding="0"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#F0F2F5" CornerRadius="5" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔍 Tìm cầu thủ:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBox}" Height="35" Padding="5,0" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Column="3" Text="Lọc theo Đội:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="4" ItemsSource="{Binding DanhSachDoiBongFilter}" SelectedItem="{Binding SelectedFilterDoiBong}" DisplayMemberPath="TenDoi" Height="35" Padding="5"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="3" ItemsSource="{Binding DanhSachCauThu}" SelectedItem="{Binding SelectedCauThu}" 
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  Background="Transparent" BorderBrush="#E0E0E0" BorderThickness="1" RowHeight="35" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F2F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Họ tên" Binding="{Binding HoTen}" Width="*" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Tuổi" Binding="{Binding Tuoi}" Width="60"/>
                <DataGridTextColumn Header="Số áo" Binding="{Binding SoAo}" Width="60"/>
                <DataGridTextColumn Header="Vị trí" Binding="{Binding ViTri}" Width="120"/>
                <DataGridTextColumn Header="Đội bóng chủ quản" Binding="{Binding DoiBong.TenDoi}" Width="200"/>
                <DataGridTextColumn Header="Bàn thắng" Binding="{Binding SoBanThang}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>