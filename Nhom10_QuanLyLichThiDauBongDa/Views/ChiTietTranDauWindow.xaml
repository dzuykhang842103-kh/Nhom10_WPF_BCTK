<Window x:Class="Nhom10_QuanLyLichThiDauBongDa.Views.ChiTietTranDauWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cập Nhật Diễn Biến Trận Đấu" Height="500" Width="800" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#F4F6F9">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding TranDauHienTai.DoiBong1.TenDoi}" Foreground="White" FontSize="20" FontWeight="Bold" Width="200" TextAlignment="Right"/>
                <TextBlock Text="{Binding TranDauHienTai.BanThangNha}" Foreground="#F1C40F" FontSize="24" FontWeight="Bold" Margin="15,0"/>
                <TextBlock Text="-" Foreground="White" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="{Binding TranDauHienTai.BanThangKhach}" Foreground="#F1C40F" FontSize="24" FontWeight="Bold" Margin="15,0"/>
                <TextBlock Text="{Binding TranDauHienTai.DoiBong.TenDoi}" Foreground="White" FontSize="20" FontWeight="Bold" Width="200" TextAlignment="Left"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Cầu thủ:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding DanhSachCauThu}" SelectedItem="{Binding SelectedCauThu}" DisplayMemberPath="HoTen" Height="30"/>

                <TextBlock Grid.Column="3" Text="Sự kiện:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="4" ItemsSource="{Binding DanhSachLoaiSuKien}" SelectedItem="{Binding SelectedLoaiSuKien}" Height="30"/>

                <TextBlock Grid.Column="6" Text="Phút:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <TextBox Grid.Column="7" Text="{Binding PhutThu}" Height="30" VerticalContentAlignment="Center"/>

                <StackPanel Grid.Column="8" Orientation="Horizontal" Margin="15,0,0,0">
                    <Button Content="Thêm" Command="{Binding ThemSuKienCommand}" Background="#27AE60" Foreground="White" FontWeight="Bold" Height="30" Width="60" Margin="0,0,10,0"/>
                    <Button Content="Xóa" Command="{Binding XoaSuKienCommand}" Background="#E74C3C" Foreground="White" FontWeight="Bold" Height="30" Width="60"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSachSuKien}" SelectedItem="{Binding SelectedSuKien}" 
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Phút" Binding="{Binding PhutThu}" Width="80"/>
                <DataGridTextColumn Header="Cầu thủ" Binding="{Binding CauThu.HoTen}" Width="200" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Đội bóng" Binding="{Binding CauThu.DoiBong.TenDoi}" Width="150"/>
                <DataGridTextColumn Header="Sự kiện" Binding="{Binding LoaiSuKien}" Width="*"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Xóa sự kiện này" Command="{Binding XoaSuKienCommand}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </Grid>
</Window>